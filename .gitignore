.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# テスト用フィクスチャは外部サイト由来なので track しない
# 取得は scripts/fetch_fixtures.py 経由 (未取得ならテストは自動 skip)
tests/fixtures/*.html

# IDE / OS
.DS_Store
.vscode/
.idea/
*.swp
*~

# Local scratch
_scratch/
/tmp/

# Local-only writing 
blog.md

# 公開前セルフチェック用 (公開リポには含めない、手元のみ)
scripts/check_publication_risk.py
