# Lockfile (公開リポではユーザの uv sync で fresh resolve させる)
uv.lock

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/

# Virtual environments
.venv/
venv/
env/

# Outputs (生成物)
out/
*.vtt
*.html
*.txt
*.wav
*.mp3
*.mp4
*.m4a
*_transcript.json
*_mlx.json
